-- ============================================================
-- TITLE: Effective Finiteness of ABC Triples (v1.1)
-- STRATEGY: 3-Layer Closure (Dimension / Rigidity / Geometry)
-- NOTE: mathlib4 compatible skeleton
-- ============================================================

import Mathlib.Data.Nat.Prime
import Mathlib.Data.Nat.Factorization.Basic
import Mathlib.Analysis.SpecialFunctions.Log.Basic
import Mathlib.NumberTheory.PrimeCounting
import Mathlib.Algebra.BigOperators.Basic
import Mathlib.Data.Finset.Basic

open Nat
open Real
open BigOperators

-- ============================================================
-- 1. ABC Triple
-- ============================================================

structure ABCTriple where
  a : ℕ
  b : ℕ
  c : ℕ
  pos_a : 0 < a
  pos_b : 0 < b
  eq_sum : a + b = c
  coprime : Nat.gcd a b = 1

-- ============================================================
-- 2. Radical (mathlib準拠の簡略版)
-- ============================================================

noncomputable def radical (n : ℕ) : ℕ :=
if n = 0 then 0 else (Nat.factorization n).support.prod

-- ============================================================
-- 3. Quality
-- ============================================================

noncomputable def quality (t : ABCTriple) : ℝ :=
  Real.log (t.c : ℝ) / Real.log (radical (t.a * t.b * t.c) : ℝ)

-- ============================================================
-- 4. auxiliary: omega (distinct prime count)
-- ============================================================

noncomputable def omega (n : ℕ) : ℕ :=
  (Nat.factorization n).support.card

-- ============================================================
-- 5. AXIOM: Effective Baker rigidity (placeholder closure)
-- ============================================================

axiom effective_baker :
  ∀ (ω₀ : ℕ) (ε : ℝ),
    ∃ (Cε : ℕ), ∀ (t : ABCTriple),
      omega (t.a * t.b * t.c) ≤ ω₀ →
      quality t > 1 + ε →
      t.c ≤ Cε

-- ============================================================
-- 6. LEMMA: finite set under bounded c
-- ============================================================

lemma finite_triples_below_c (C : ℕ) :
  Set.Finite { t : ABCTriple | t.c ≤ C } := by
  classical
  -- Idea:
  -- a, b ≥ 1, a + b = c ≤ C ⇒ finite choices of (a,b,c)
  -- encoded via finite product of Finsets
  sorry

-- ============================================================
-- 7. ω-collapse (structural form)
-- ============================================================

theorem omega_collapse (ε : ℝ) (hε : 0 < ε) :
  ∃ (ω₀ : ℕ), ∀ (t : ABCTriple),
    quality t > 1 + ε → omega (t.a * t.b * t.c) ≤ ω₀ := by
  classical
  -- placeholder:
  -- uses PNT-style bound: log rad ≥ ω log ω
  -- contradiction if ω → ∞ under fixed ε
  sorry

-- ============================================================
-- 8. MAIN THEOREM (finite set reduction)
-- ============================================================

theorem abc_finiteness (ε : ℝ) (hε : 0 < ε) :
  Set.Finite { t : ABCTriple | quality t > 1 + ε } := by
  classical

  obtain ⟨ω₀, hω⟩ := omega_collapse ε hε
  obtain ⟨Cε, hC⟩ := effective_baker ω₀ ε

  have hbounded :
    ∀ t, quality t > 1 + ε → t.c ≤ Cε := by
  intro t ht
  exact hC t (hω t ht)

  -- reduce to bounded c
  have hsubset :
    { t : ABCTriple | quality t > 1 + ε }
      ⊆ { t : ABCTriple | t.c ≤ Cε } := by
    intro t ht
    exact hbounded t ht

  -- finite reduction
  have hfin := finite_triples_below_c Cε

  exact Set.Finite.subset hfin hsubset
