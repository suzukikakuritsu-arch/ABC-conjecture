import ABC.Arithmetic

namespace ABC

-- ============================================================
-- ωのログ上界（既に証明済み想定）
-- ============================================================

theorem omega_log_bound (n : Nat) (h : 1 < n) :
  omega n ≤ Nat.log2 (n + 1) := by
  -- Arithmetic側の結果を使用
  exact omega_bound_by_log n (by
    have : 2 ≤ n := Nat.succ_le_of_lt h
    exact this)

